---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Newsletter from "../components/Newsletter.astro";
import Icon from "../components/Icon.astro";
import autumnScene from "../assets/rocket.png";
import {
  SITE,
  categories,
  sortedPosts,
  getAuthor,
  getCategory,
  formatDate,
} from "../lib/blog-data.js";

const allPosts = await sortedPosts();
const top4 = allPosts.slice(0, 4);

// Remaining 4 posts for the split panels
const post5 = allPosts[4];
const post6 = allPosts[5];
const post7 = allPosts[6];
const post8 = allPosts[7];

// Authors for the double-profile panel
const samuel = getAuthor("samuel-okafor");
const mira = getAuthor("mira-iwasaki");
---

<BaseLayout
  title={`${SITE.name} - Create to Inspire, Inspire to Change`}
  description={SITE.description}
  canonical="/"
  flushFooter
>
  <!-- TOP ROW: 4-COLUMN GALLERY -->
  <section class="grid grid-cols-2 md:grid-cols-4 border-b border-border bg-background">
    {
      top4.map((post, i) => {
        const cat = getCategory(post.category);
        return (
          <a
            href={`/blog/${post.slug}`}
            class={`group block p-4 sm:p-6 transition-colors hover:bg-muted/10 border-b border-border md:border-b-0 ${i < 3 ? "border-r border-border" : ""} ${i === 2 ? "border-r-0 md:border-r" : ""}`}
          >
            <div class="aspect-[4/3] overflow-hidden bg-muted border border-border">
              {post.thumbnail && (
                <Image
                  src={post.thumbnail}
                  alt={post.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="eager"
                />
              )}
            </div>
            <div class="mt-4">
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">{cat?.name}</span>
              <h3 class="mt-1 font-serif text-base font-semibold leading-tight text-foreground group-hover:text-primary transition-colors line-clamp-2">
                {post.title}
              </h3>
              <time class="mt-1 block font-mono text-[9px] uppercase tracking-wider text-muted-foreground">{formatDate(post.date)}</time>
            </div>
          </a>
        );
      })
    }
  </section>
 <section class="relative -mt-[calc(4rem+2px)] min-h-[calc(100svh-2rem)] overflow-hidden border-b border-border/60 pt-[calc(4rem+2px)] sm:min-h-[760px]">
    <Image
      src={autumnScene}
      alt=""
      class="absolute inset-0 h-full w-full object-cover object-center"
      loading="eager"
      decoding="async"
      widths={[640, 960, 1280, 1920, 2560]}
      sizes="100vw"
    />
    <div
      aria-hidden="true"
      class="absolute inset-0 bg-[linear-gradient(90deg,oklch(0.1_0.02_70_/_0.68),oklch(0.16_0.02_80_/_0.38)_46%,oklch(0.98_0.01_90_/_0.1))] dark:bg-[linear-gradient(90deg,oklch(0.08_0.01_70_/_0.78),oklch(0.08_0.01_70_/_0.52)_48%,oklch(0.08_0.01_70_/_0.18))]"
    />
    <div
      aria-hidden="true"
      class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-black/45 via-black/18 to-transparent"
    />
    <div
      aria-hidden="true"
      class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-t from-background via-background/72 to-transparent"
    />
    <div class="relative mx-auto flex min-h-[calc(100svh-6rem)] max-w-6xl items-center px-5 py-20 sm:min-h-[680px] sm:py-24">
      <div class="max-w-4xl text-white drop-shadow-[0_1px_18px_rgba(0,0,0,0.28)]">
        <h1 class="font-serif text-[2.5rem] font-medium leading-[1.02] tracking-[-0.02em] sm:text-6xl lg:text-7xl">
        Stingmag is our Philosophy to Create to Inspire and Inspire
          <span class="italic text-white"> to Change</span>,
          <span class="italic text-white"> and make the world</span>
          <span class="italic text-white"> Heal through Art</span>.
        </h1>
        <p class="mt-8 max-w-xl text-lg leading-relaxed text-white/86">
         Stingmag, started has a movemnt for us to tell stories of Big things happening in Small places and curation of our lifes and culture to bring taste into the game
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-4">
          <a
            href={`/blog/${allPosts[0]?.slug}`}
            class="group inline-flex items-center gap-2 border-b border-white pb-1 text-sm font-medium text-white hover:border-white/70 hover:text-white/82"
          >
            Start with STINGMAG ISSU_#001 : INFLUENCE on digital or get PRINT ON STORE
            <Icon name="arrow-right" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" />
          </a>
          <a href="/blog" class="text-sm text-white/76 hover:text-white">
            Or browse the archive
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ROW 1: MANIFESTO & FEATURED SPLIT -->
  <section class="grid md:grid-cols-2 border-b border-border">
    <div class="bg-primary p-8 sm:p-12 md:p-16 flex flex-col justify-center text-white border-b border-border md:border-b-0 md:border-r border-border">
      <div class="font-mono text-xs uppercase tracking-[0.25em] text-white/80">Manifesto</div>
      <h2 class="mt-6 font-sans text-3xl sm:text-4xl lg:text-5xl font-black leading-[1.05] tracking-tight uppercase">
        StingMag is Sting philosophy to Create to Inspire and Inspire to Change.
      </h2>
      <p class="mt-6 max-w-lg font-serif text-base sm:text-lg leading-relaxed text-white/90">
        We started the digital magazine to tell the stories of Big things happening in small places, through the Lens of culture and taste.
      </p>
    </div>
    <div class="relative group aspect-[16/10] md:aspect-auto overflow-hidden bg-muted flex items-center justify-center">
      {allPosts[0]?.thumbnail && (
        <Image
          src={allPosts[0].thumbnail}
          alt={allPosts[0].title}
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      )}
      <div class="absolute inset-0 bg-black/35 group-hover:bg-black/20 transition-colors"></div>
      <a href={`/blog/${allPosts[0]?.slug}`} class="relative z-10 p-8 text-center text-white">
        <span class="font-mono text-xs uppercase tracking-[0.2em] text-primary bg-black/60 px-3 py-1">Featured Issue</span>
        <h3 class="mt-4 font-sans text-2xl sm:text-3xl lg:text-4xl font-extrabold uppercase tracking-tight max-w-xl leading-none">
          {allPosts[0]?.title}
        </h3>
        <span class="mt-4 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-wider underline underline-offset-4">
          Read Feature &rarr;
        </span>
      </a>
    </div>
  </section>

  <!-- ROW 2: FULL-BLEED STATEMENT -->
  <section class="relative h-[480px] w-full border-b border-border overflow-hidden group">
    <Image
      src={autumnScene}
      alt="Manifesto Background"
      class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-700 group-hover:scale-[1.03]"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-black/80"></div>
    <div class="absolute inset-0 flex flex-col justify-center items-center p-6 text-center z-10">
      <div class="font-mono text-xs uppercase tracking-[0.3em] text-primary">Sting Philosophy</div>
      <h2 class="mt-6 font-sans text-3xl sm:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tighter uppercase text-white max-w-4xl">
        WE BELIEVE IN EXTREME AUTHENTICITY AND BRUTAL STORYTELLING. WE BRING THE TRUTH TO THE WORLD.
      </h2>
      <div class="mt-8 flex gap-4">
        <a href="/blog" class="font-mono text-xs uppercase tracking-widest border border-white px-6 py-3 text-white hover:bg-white hover:text-black transition-all">
          Browse Archive
        </a>
      </div>
    </div>
  </section>

  <!-- ROW 3: POST 5 SPLIT (BLACK BACKGROUND) -->
  {post5 && (
    <section class="grid md:grid-cols-2 border-b border-border bg-black text-white">
      <div class="relative group aspect-[16/10] md:aspect-auto overflow-hidden bg-muted border-b border-border md:border-b-0 md:border-r border-border">
        {post5.thumbnail && (
          <Image
            src={post5.thumbnail}
            alt={post5.title}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        )}
      </div>
      <div class="p-8 sm:p-12 md:p-16 flex flex-col justify-center">
        <span class="font-mono text-xs uppercase tracking-[0.2em] text-primary">{getCategory(post5.category)?.name}</span>
        <a href={`/blog/${post5.slug}`} class="group">
          <h2 class="mt-4 font-sans text-2xl sm:text-3xl lg:text-4xl font-extrabold uppercase tracking-tight group-hover:text-primary transition-colors leading-tight">
            {post5.title}
          </h2>
        </a>
        <p class="mt-4 text-sm sm:text-base leading-relaxed text-muted-foreground max-w-lg">
          {post5.excerpt}
        </p>
        <div class="mt-6 flex items-center gap-4 text-xs font-mono uppercase tracking-wider text-muted-foreground">
          <span>{formatDate(post5.date)}</span>
          <span>&middot;</span>
          <span>{post5.readingTime} min read</span>
        </div>
      </div>
    </section>
  )}

  <!-- ROW 4: POST 6 SPLIT (WHITE BACKGROUND) -->
  {post6 && (
    <section class="grid md:grid-cols-2 border-b border-border bg-background text-foreground">
      <div class="p-8 sm:p-12 md:p-16 flex flex-col justify-center order-2 md:order-1 border-t border-border md:border-t-0 md:border-r border-border">
        <span class="font-mono text-xs uppercase tracking-[0.2em] text-primary">{getCategory(post6.category)?.name}</span>
        <a href={`/blog/${post6.slug}`} class="group">
          <h2 class="mt-4 font-sans text-2xl sm:text-3xl lg:text-4xl font-extrabold uppercase tracking-tight group-hover:text-primary transition-colors leading-tight">
            {post6.title}
          </h2>
        </a>
        <p class="mt-4 text-sm sm:text-base leading-relaxed text-muted-foreground max-w-lg">
          {post6.excerpt}
        </p>
        <div class="mt-6 flex items-center gap-4 text-xs font-mono uppercase tracking-wider text-muted-foreground">
          <span>{formatDate(post6.date)}</span>
          <span>&middot;</span>
          <span>{post6.readingTime} min read</span>
        </div>
      </div>
      <div class="relative group aspect-[16/10] md:aspect-auto overflow-hidden bg-muted order-1 md:order-2">
        {post6.thumbnail && (
          <Image
            src={post6.thumbnail}
            alt={post6.title}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        )}
      </div>
    </section>
  )}

  <!-- ROW 5: POST 7 SPLIT (RED BACKGROUND) -->
  {post7 && (
    <section class="grid md:grid-cols-2 border-b border-border bg-primary text-white">
      <div class="relative group aspect-[16/10] md:aspect-auto overflow-hidden bg-muted border-b border-border md:border-b-0 md:border-r border-border">
        {post7.thumbnail && (
          <Image
            src={post7.thumbnail}
            alt={post7.title}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        )}
      </div>
      <div class="p-8 sm:p-12 md:p-16 flex flex-col justify-center">
        <span class="font-mono text-xs uppercase tracking-[0.2em] text-white/80">{getCategory(post7.category)?.name}</span>
        <a href={`/blog/${post7.slug}`} class="group">
          <h2 class="mt-4 font-sans text-2xl sm:text-3xl lg:text-4xl font-extrabold uppercase tracking-tight text-white hover:text-black transition-colors leading-tight">
            {post7.title}
          </h2>
        </a>
        <p class="mt-4 text-sm sm:text-base leading-relaxed text-white/90 max-w-lg">
          {post7.excerpt}
        </p>
        <div class="mt-6 flex items-center gap-4 text-xs font-mono uppercase tracking-wider text-white/80">
          <span>{formatDate(post7.date)}</span>
          <span>&middot;</span>
          <span>{post7.readingTime} min read</span>
        </div>
      </div>
    </section>
  )}

  <!-- ROW 6: POST 8 SPLIT (BLACK BACKGROUND) -->
  {post8 && (
    <section class="grid md:grid-cols-2 border-b border-border bg-black text-white">
      <div class="p-8 sm:p-12 md:p-16 flex flex-col justify-center order-2 md:order-1 border-t border-border md:border-t-0 md:border-r border-border">
        <span class="font-mono text-xs uppercase tracking-[0.2em] text-primary">{getCategory(post8.category)?.name}</span>
        <a href={`/blog/${post8.slug}`} class="group">
          <h2 class="mt-4 font-sans text-2xl sm:text-3xl lg:text-4xl font-extrabold uppercase tracking-tight group-hover:text-primary transition-colors leading-tight">
            {post8.title}
          </h2>
        </a>
        <p class="mt-4 text-sm sm:text-base leading-relaxed text-muted-foreground max-w-lg">
          {post8.excerpt}
        </p>
        <div class="mt-6 flex items-center gap-4 text-xs font-mono uppercase tracking-wider text-muted-foreground">
          <span>{formatDate(post8.date)}</span>
          <span>&middot;</span>
          <span>{post8.readingTime} min read</span>
        </div>
      </div>
      <div class="relative group aspect-[16/10] md:aspect-auto overflow-hidden bg-muted order-1 md:order-2">
        {post8.thumbnail && (
          <Image
            src={post8.thumbnail}
            alt={post8.title}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        )}
      </div>
    </section>
  )}

  <!-- ROW 7: DOUBLE AUTHOR SPLIT PROFILE (SAMUEL & MIRA) -->
  <section class="grid md:grid-cols-2 border-b border-border bg-background">
    {samuel && (
      <div class="p-8 sm:p-12 md:p-16 flex flex-col items-center text-center border-b border-border md:border-b-0 md:border-r border-border">
        <Image
          src={samuel.avatar}
          alt={samuel.name}
          width={120}
          height={120}
          class="h-24 w-24 border border-border object-cover"
        />
        <span class="mt-6 font-mono text-xs uppercase tracking-[0.2em] text-primary">Contributor</span>
        <h3 class="mt-2 font-sans text-xl font-bold uppercase tracking-tight">{samuel.name}</h3>
        <p class="mt-4 max-w-md text-sm text-muted-foreground leading-relaxed">
          {samuel.longBio}
        </p>
        <a href={`/authors/${samuel.slug}`} class="mt-6 font-mono text-xs uppercase tracking-wider underline underline-offset-4 text-foreground hover:text-primary">
          View essays &rarr;
        </a>
      </div>
    )}
    {mira && (
      <div class="p-8 sm:p-12 md:p-16 flex flex-col items-center text-center">
        <Image
          src={mira.avatar}
          alt={mira.name}
          width={120}
          height={120}
          class="h-24 w-24 border border-border object-cover"
        />
        <span class="mt-6 font-mono text-xs uppercase tracking-[0.2em] text-primary">Contributor</span>
        <h3 class="mt-2 font-sans text-xl font-bold uppercase tracking-tight">{mira.name}</h3>
        <p class="mt-4 max-w-md text-sm text-muted-foreground leading-relaxed">
          {mira.longBio}
        </p>
        <a href={`/authors/${mira.slug}`} class="mt-6 font-mono text-xs uppercase tracking-wider underline underline-offset-4 text-foreground hover:text-primary">
          View essays &rarr;
        </a>
      </div>
    )}
  </section>

  <!-- NEWSLETTER BLOCK -->
  <section class="border-b border-border bg-background">
    <Newsletter />
  </section>
</BaseLayout>
